# --- OSC: re-paint terminal palette to match this scheme ---
# Sourcing this file repaints the connected terminal via OSC sequences.
# Guarded to skip non-interactive shells so scripts do not emit escapes.
if [[ -t 1 ]]; then
  printf '\e]10;%s\a' "#ffffff"
  printf '\e]11;%s\a' "#282c34"
  printf '\e]12;%s\a' "#e5c8b9"
  printf '\e]4;0;%s\a'  "#353a44"
