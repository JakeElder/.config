  printf '\e]4;5;%s\a'  "#dba8a8"
  printf '\e]4;6;%s\a'  "#70c0b1"
  printf '\e]4;7;%s\a'  "#eaeaea"
  printf '\e]4;8;%s\a'  "#4d4d4d"
  printf '\e]4;9;%s\a'  "#d54e53"
  printf '\e]4;10;%s\a' "#b5bd68"
  printf '\e]4;11;%s\a' "#e7c547"
  printf '\e]4;12;%s\a' "#81a2be"
  printf '\e]4;13;%s\a' "#dba8a8"
  printf '\e]4;14;%s\a' "#70c0b1"
  printf '\e]4;15;%s\a' "#d8d9d8"
fi
